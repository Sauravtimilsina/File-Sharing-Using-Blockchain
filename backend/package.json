{
  "name": "secure-file-transfer-backend",
  "version": "1.0.0",
  "description": "Express API for encrypted file transfer, OTP authentication, Supabase storage, and SHA-256 integrity verification.",
  "main": "src/server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "check:email": "node scripts/checkEmailProvider.js",
    "check:smtp": "node scripts/checkSmtp.js",
    "check:supabase": "node scripts/checkSupabase.js",
    "check:file-storage": "node scripts/checkFileStorageServices.js",
    "resend:otp": "node scripts/resendVerificationOtp.js",
    "migrate:local-files-to-storage": "node scripts/migrateLocalFilesToStorage.js",
    "migrate:postgres-to-postgres": "node scripts/migratePostgresToPostgres.js",
    "generate:secrets": "node scripts/generateSecrets.js",
    "encrypt:profiles": "node scripts/encryptExistingProfiles.js",
    "encrypt:metadata": "node scripts/encryptExistingProfiles.js",
    "restore:tracked-html-upload": "node scripts/restoreTrackedEncryptedFile.js"
  },
  "keywords": [
    "secure-file-transfer",
    "encrypted-file-sharing",
    "nodejs",
    "express",
    "supabase",
    "jwt",
    "otp",
    "aes-encryption",
    "sha256",
    "cybersecurity"
  ],
  "author": "Saurav Timilsina",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
