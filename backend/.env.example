PORT=5000
NODE_ENV=development
# Backend-only configuration. Do not copy Supabase keys, database URLs, JWT/OTP
# secrets, SMTP credentials, or ENCRYPTION_KEY into frontend/.env.
DB_PROVIDER=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_DB_URL=postgresql://postgres:your_database_password@db.your-project-ref.supabase.co:5432/postgres
SOURCE_SUPABASE_DB_URL=postgresql://postgres:source_database_password@db.source_project_ref.supabase.co:5432/postgres
CLIENT_ORIGINS=http://localhost:5173
MAX_UPLOAD_BYTES=1073741824
UPLOAD_TMP_DIR=
FILE_STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=encrypted-files
JWT_SECRET=generate_with_npm_run_generate_secrets
OTP_SECRET=generate_with_npm_run_generate_secrets
ENCRYPTION_KEY=generate_with_npm_run_generate_secrets
# ENCRYPTION_KEY protects encrypted file objects and encrypted profile fields.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mailbox@example.com
SMTP_PASS=mail_password_or_app_password
SMTP_FROM=mailbox@example.com
RESTORE_FILE_OWNER_EMAIL=owner@example.com
